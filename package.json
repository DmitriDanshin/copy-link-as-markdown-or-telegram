  },
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "preview": "wxt",
    "test": "vitest",
    "postinstall": "wxt prepare",
    "storybook": "ladle serve",
    "build-storybook": "ladle build",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "typecheck": "tsc --noEmit",
    "fmt": "oxfmt entrypoints/ src/ wxt.config.ts",
    "fmt:check": "oxfmt --check entrypoints/ src/ wxt.config.ts",
    "lint": "oxlint entrypoints/ src/",
    "lint:fix": "oxlint --fix entrypoints/ src/",
    "release": "npm run lint && npm run build && standard-version",
    "release:dry-run": "standard-version --dry-run"
  },
  "dependencies": {
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
