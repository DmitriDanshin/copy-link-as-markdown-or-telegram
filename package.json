    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@ladle/react": "^5.1.1",
    "@types/chrome": "0.0.332",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@wxt-dev/module-react": "^1.1.3",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.50.0",
